# =========================================
# Core
# =========================================
NODE_ENV=test
PORT=5001
DATABASE_URL=postgresql://postgres:password@localhost:5432/dodgerjsocial_test
JWT_SECRET=test_jwt_secret_change_me

# Frontend / CORS
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# =========================================
# Realtime / Redis
# Usually optional for tests
# =========================================
REDIS_URL=

# =========================================
# Storage
# Keep tests deterministic unless test cases require external storage.
# =========================================
STORAGE_PROVIDER=local

# --- Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- S3
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=false

# =========================================
# Whisper
# Usually optional in tests unless explicitly covered by tests
# =========================================
WHISPER_PYTHON=python
WHISPER_SCRIPT=
WHISPER_MODEL=

# =========================================
# Moderation / Cron
# Better disabled in most tests
# =========================================
MODERATION_OUTBOX_ENABLED=false
STORY_CLEANER_ENABLED=false

# =========================================
# Seed privileged user
# Optional for tests
# =========================================
SEED_EMAIL=
SEED_USERNAME=
SEED_PASSWORD=
SEED_ROLE=ADMIN