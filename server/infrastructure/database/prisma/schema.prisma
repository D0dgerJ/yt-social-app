// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int      @id @default(autoincrement())
  username       String   @unique
  email          String   @unique
  password       String
  profilePicture String? // Cloudinary URL
  coverPicture   String? // Cloudinary URL
  desc           String?  @default("")
  role           UserRole @default(USER)
  from           String?  @default("Ghana")
  city           String?  @default("Accra")
  relationship   Int?     @default(1)

  posts        Post[]
  likes        Like[]
  comments     Comment[]
  commentLikes CommentLike[]
  messages     Message[]
  savedPosts   SavedPost[]
  stories      Story[]
  storyViews   StoryView[]

  sentRequests     FriendRequest[] @relation("SentRequests")
  receivedRequests FriendRequest[] @relation("ReceivedRequests")

  notificationsFrom Notification[] @relation("NotificationFrom")
  notificationsTo   Notification[] @relation("NotificationTo")

  followedBy Follow[] @relation("FollowedBy")
  following  Follow[] @relation("Following")

  participants Participant[]

  messageReactions Reaction[]

  encryptionKeys    EncryptionKey[]
  reportsSent       Report[]          @relation("ReportsSent")
  mediaFiles        MediaFile[]
  messageDeliveries MessageDelivery[]
  devices           Device[]
  messageMentions   Message[]         @relation("MessageMentions")

  pinnedConversations PinnedConversation[]
  pinnedMessages      PinnedMessage[]

  messageViews MessageView[]

  events Event[]

  moderationActions ModerationAction[]
  moderationSubjectActions ModerationAction[] @relation("ModerationActionSubjectUser")
  hiddenPosts       Post[]             @relation("PostHiddenBy")
  deletedPosts      Post[]             @relation("PostDeletedBy")

  postReportsSent     PostReport[] @relation("PostReportReporter")
  postReportsReviewed PostReport[] @relation("PostReportReviewedBy")

  sanctions        UserSanction[] @relation("UserSanctions")
  sanctionsCreated UserSanction[] @relation("SanctionCreatedBy")
  sanctionsLifted  UserSanction[] @relation("SanctionLiftedBy")

  commentReportsCreated  CommentReport[] @relation("CommentReportReporter")
  commentReportsReviewed CommentReport[] @relation("CommentReportReviewedBy")

  commentsHidden       Comment[] @relation("CommentHiddenBy")
  commentsDeleted      Comment[] @relation("CommentDeletedBy")
  commentsShadowHidden Comment[] @relation("CommentShadowHiddenBy")
}

model FriendRequest {
  id         Int      @id @default(autoincrement())
  sender     User     @relation("SentRequests", fields: [senderId], references: [id])
  senderId   Int
  receiver   User     @relation("ReceivedRequests", fields: [receiverId], references: [id])
  receiverId Int
  status     String   @default("pending") // "pending", "accepted", "rejected"
  createdAt  DateTime @default(now())

  @@unique([senderId, receiverId])
}

model Post {
  id        Int     @id @default(autoincrement())
  userId    Int
  user      User    @relation(fields: [userId], references: [id])
  desc      String?
  mediaUrl  String?
  mediaType String  @default("image") // image / video

  likes    Like[]
  comments Comment[]
  savedBy  SavedPost[]
  postTags PostTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images String[] @default([]) // массив URL-ов к изображениям
  videos String[] @default([]) // массив URL-ов к видео
  files  String[] @default([]) // любые другие файлы

  tags     String[] @default([]) // новый массив тегов
  location String? // необязательная строка (город, страна и т.п.)

  status ContentStatus @default(ACTIVE)

  hiddenAt     DateTime?
  hiddenById   Int?
  hiddenBy     User?     @relation("PostHiddenBy", fields: [hiddenById], references: [id], onDelete: SetNull)
  hiddenReason String?

  deletedAt     DateTime?
  deletedById   Int?
  deletedBy     User?        @relation("PostDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  deletedReason String?
  postReports   PostReport[]

  @@index([status, createdAt])
}

model Like {
  id     Int  @id @default(autoincrement())
  userId Int
  postId Int
  user   User @relation(fields: [userId], references: [id])
  post   Post @relation(fields: [postId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, postId], name: "userId_postId")
  @@index([userId, createdAt])
}

model Comment {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int
  content   String
  images    String[] @default([])
  videos    String[] @default([])
  files     String[] @default([])
  createdAt DateTime @default(now())

  parentId Int?
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentReplies")

  post  Post          @relation(fields: [postId], references: [id])
  user  User          @relation(fields: [userId], references: [id])
  likes CommentLike[]

  status CommentStatus @default(ACTIVE)

  visibility CommentVisibility @default(PUBLIC)

  shadowHiddenAt     DateTime?
  shadowHiddenReason String?
  shadowHiddenById   Int?
  shadowHiddenBy     User?     @relation("CommentShadowHiddenBy", fields: [shadowHiddenById], references: [id], onDelete: SetNull)

  hiddenAt     DateTime?
  hiddenReason String?
  hiddenById   Int?
  hiddenBy     User?     @relation("CommentHiddenBy", fields: [hiddenById], references: [id], onDelete: SetNull)

  deletedAt     DateTime?
  deletedReason String?
  deletedById   Int?
  deletedBy     User?     @relation("CommentDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)

  reports CommentReport[]

  @@index([status])
  @@index([visibility])
  @@index([postId, status])
  @@index([postId, visibility])
  @@index([parentId, status])
  @@index([parentId, visibility])
}

model CommentLike {
  id        Int      @id @default(autoincrement())
  userId    Int
  commentId Int
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  comment Comment @relation(fields: [commentId], references: [id])

  @@unique([userId, commentId], name: "userId_commentId")
}

model Follow {
  id          Int  @id @default(autoincrement())
  followerId  Int
  followingId Int
  follower    User @relation("Following", fields: [followerId], references: [id])
  following   User @relation("FollowedBy", fields: [followingId], references: [id])

  @@unique([followerId, followingId], name: "followerId_followingId")
}

model Notification {
  id         Int      @id @default(autoincrement())
  type       String // 'like', 'comment', 'follow', etc.
  content    String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  fromUser   User     @relation("NotificationFrom", fields: [fromUserId], references: [id])
  fromUserId Int
  toUser     User     @relation("NotificationTo", fields: [toUserId], references: [id])
  toUserId   Int

  @@index([toUserId, isRead, createdAt])
}

model SavedPost {
  id     Int  @id @default(autoincrement())
  userId Int
  postId Int
  user   User @relation(fields: [userId], references: [id])
  post   Post @relation(fields: [postId], references: [id])

  @@unique([userId, postId], name: "userId_postId")
}

model Story {
  id        Int         @id @default(autoincrement())
  mediaUrl  String
  mediaType String // 'image' | 'video'
  userId    Int
  user      User        @relation(fields: [userId], references: [id])
  createdAt DateTime    @default(now())
  expiresAt DateTime
  views     StoryView[]
}

model StoryView {
  id        Int      @id @default(autoincrement())
  userId    Int
  storyId   Int
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  story Story @relation(fields: [storyId], references: [id])

  @@unique([userId, storyId])
}

model Conversation {
  id        Int      @id @default(autoincrement())
  name      String? // только для групп
  isGroup   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants Participant[]
  messages     Message[]

  lastMessageId Int?     @unique
  lastMessage   Message? @relation("LastMessage", fields: [lastMessageId], references: [id])

  pinnedBy       PinnedConversation[]
  pinnedMessages PinnedMessage[]
}

model Participant {
  id             Int          @id @default(autoincrement())
  userId         Int
  conversationId Int
  user           User         @relation(fields: [userId], references: [id])
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  joinedAt             DateTime  @default(now())
  isOnline             Boolean   @default(false)
  receiveNotifications Boolean   @default(true)
  role                 String    @default("member") // member | admin | owner
  mutedUntil           DateTime? // для временного отключения уведомлений

  @@unique([userId, conversationId])
}

model Message {
  id             Int @id @default(autoincrement())
  conversationId Int
  senderId       Int

  encryptedContent String?
  mediaUrl         String?
  mediaType        String? // image | video | file | gif | audio | text
  fileName         String?
  gifUrl           String?
  stickerUrl       String?
  audioText        String?

  audioOriginalUrl String? // URL оригинала
  audioUrl         String? // URL сконвертированного файла
  audioMime        String? // итоговый MIME
  audioDurationSec Int? // длительность в секундах
  audioWaveform    Int[]             @default([]) // компактная волна (32–64 значений)
  processingStatus ProcessingStatus? // PENDING | PROCESSING | READY | FAILED

  isDelivered Boolean   @default(false)
  isRead      Boolean   @default(false)
  isEdited    Boolean   @default(false)
  editedAt    DateTime?

  repliedToId Int?
  repliedTo   Message?  @relation("MessageReplies", fields: [repliedToId], references: [id])
  replies     Message[] @relation("MessageReplies")

  conversation                Conversation  @relation(fields: [conversationId], references: [id])
  conversationWithLastMessage Conversation? @relation("LastMessage")
  sender                      User          @relation(fields: [senderId], references: [id])
  reactions                   Reaction[]
  createdAt                   DateTime      @default(now())

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  mentions User[] @relation("MessageMentions")

  reports    Report[]
  mediaFiles MediaFile[]
  deliveries MessageDelivery[]

  clientMessageId String? @unique

  pinnedBy PinnedMessage[]

  // ⏱/👁 Эфемерные сообщения
  isEphemeral     Boolean   @default(false) // является ли сообщение самоуничтожающимся
  expiresAt       DateTime? // удалить после этой даты/времени (режим по времени)
  maxViewsPerUser Int? // максимум просмотров для КАЖДОГО пользователя (режим по просмотрам)

  // учёт просмотров по пользователям
  views MessageView[]

  @@index([conversationId, createdAt])
  @@index([conversationId, editedAt])
  @@index([conversationId, deletedAt])
  @@index([processingStatus, createdAt])
}

// 👁 Учёт просмотров эфемерных сообщений по пользователям
model MessageView {
  id           Int       @id @default(autoincrement())
  messageId    Int
  userId       Int
  viewCount    Int       @default(0)
  lastViewedAt DateTime? // опционально, можно использовать для логики

  message Message @relation(fields: [messageId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
}

model EncryptionKey {
  id        Int      @id @default(autoincrement())
  userId    Int
  deviceId  String // уникальный ID устройства
  publicKey String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, deviceId])
}

model Report {
  id         Int      @id @default(autoincrement())
  reporterId Int
  messageId  Int
  reason     String
  type       String   @default("abuse") // abuse | spam | csam | terror | other
  createdAt  DateTime @default(now())
  status     String   @default("pending") // pending | reviewed | banned | rejected

  reporter User    @relation("ReportsSent", fields: [reporterId], references: [id])
  message  Message @relation(fields: [messageId], references: [id])
}

model MediaFile {
  id   Int    @id @default(autoincrement())
  url  String
  type String // image, video, audio, file, sticker, gif

  originalName String?
  mime         String? // например "application/pdf" или "image/png"
  size         Int?

  uploaderId Int
  uploadedAt DateTime @default(now())

  uploader User @relation(fields: [uploaderId], references: [id])

  messageId Int?
  message   Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model MessageDelivery {
  id        Int      @id @default(autoincrement())
  messageId Int
  userId    Int
  status    String   @default("sent") // sent | delivered | read
  timestamp DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
}

model Device {
  id        String   @id // UUID или fingerprint
  userId    Int
  name      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Reaction {
  id        Int      @id @default(autoincrement())
  emoji     String // например, ❤️, 😂, 👍
  userId    Int
  messageId Int
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  message Message @relation(fields: [messageId], references: [id])

  @@unique([userId, messageId]) // один пользователь — одна реакция на сообщение
  @@index([messageId, createdAt])
}

// 📌 Закреплённые чаты (персональные пины)
model PinnedConversation {
  id             Int      @id @default(autoincrement())
  userId         Int
  conversationId Int
  pinnedAt       DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@unique([userId, conversationId])
}

// 📌 Закреплённые сообщения (персональные пины)
model PinnedMessage {
  id             Int      @id @default(autoincrement())
  conversationId Int
  messageId      Int
  pinnedById     Int // кто закрепил
  pinnedAt       DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])
  message      Message      @relation(fields: [messageId], references: [id])
  pinnedBy     User         @relation(fields: [pinnedById], references: [id])

  @@unique([conversationId, messageId]) // одно и то же сообщение нельзя закрепить в этом же чате дважды
}

enum ProcessingStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
  OWNER
}

enum ModerationTargetType {
  POST
  COMMENT
  STORY
  USER
  MESSAGE
  OTHER
}

enum ModerationActionType {
  REPORT_CREATED
  CONTENT_HIDDEN
  CONTENT_UNHIDDEN
  CONTENT_SHADOW_HIDDEN
  CONTENT_SHADOW_UNHIDDEN
  CONTENT_DELETED
  USER_RESTRICTED
  USER_UNRESTRICTED
  USER_BANNED
  USER_UNBANNED
  NOTE
  BOT_AUTO_ACTION
}

enum ContentStatus {
  ACTIVE
  HIDDEN
  DELETED
}

model Event {
  id          Int       @id @default(autoincrement())
  userId      Int
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime?
  allDay      Boolean   @default(true)
  color       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startAt])
  @@index([userId, endAt])
}

model ModerationAction {
  id      Int   @id @default(autoincrement())
  actorId Int?
  actor   User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  actionType ModerationActionType
  targetType ModerationTargetType
  targetId   String

  subjectUserId Int?
  subjectUser   User? @relation("ModerationActionSubjectUser", fields: [subjectUserId], references: [id], onDelete: SetNull)

  reason    String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])

  @@index([subjectUserId, createdAt])
  @@index([actionType, createdAt])
}

enum OutboxStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
}

model ModerationOutbox {
  id         Int    @id @default(autoincrement())
  eventType  String
  entityType String
  entityId   String
  payload    Json

  status    OutboxStatus @default(PENDING)
  attempts  Int          @default(0)
  lastError String?
  createdAt DateTime     @default(now())
  sentAt    DateTime?

  @@index([status, createdAt])
  @@index([entityType, entityId])
}

model PostReport {
  id         Int          @id @default(autoincrement())
  postId     Int?
  reporterId Int
  reason     String
  message    String?
  status     ReportStatus @default(PENDING)

  createdAt    DateTime  @default(now())
  reviewedAt   DateTime?
  reviewedById Int?

  post Post? @relation(fields: [postId], references: [id], onDelete: SetNull)

  reporter   User  @relation("PostReportReporter", fields: [reporterId], references: [id])
  reviewedBy User? @relation("PostReportReviewedBy", fields: [reviewedById], references: [id])

  @@unique([postId, reporterId])
  @@index([status, createdAt])
  @@index([postId])
  @@index([reporterId, createdAt])
}

enum ReportStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserSanctionType {
  WARN
  RESTRICT
  TEMP_BAN
  PERM_BAN
}

enum UserSanctionStatus {
  ACTIVE
  LIFTED
  EXPIRED
}

model UserSanction {
  id     Int                @id @default(autoincrement())
  userId Int
  type   UserSanctionType
  status UserSanctionStatus @default(ACTIVE)

  reason   String
  message  String?
  evidence Json? // { postIds: number[], reportIds: number[], links: string[] ... }

  startsAt DateTime  @default(now())
  endsAt   DateTime? // null для PERM_BAN / WARN / RESTRICT

  createdById Int
  liftedById  Int?
  liftedAt    DateTime?
  liftReason  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User  @relation("UserSanctions", fields: [userId], references: [id], onDelete: Cascade)
  createdBy User  @relation("SanctionCreatedBy", fields: [createdById], references: [id])
  liftedBy  User? @relation("SanctionLiftedBy", fields: [liftedById], references: [id])

  @@index([userId, status])
  @@index([status, endsAt])
}

enum CommentVisibility {
  PUBLIC
  SHADOW_HIDDEN
}

enum CommentStatus {
  ACTIVE
  HIDDEN
  DELETED
}

enum PostTagSource {
  MANUAL
  AUTO_RULE
  AUTO_AI
  AUTO_ADMIN
}

model CommentReport {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  commentId Int
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  reporterId Int
  reporter   User @relation("CommentReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)

  reason  String
  details String?

  status       ReportStatus @default(PENDING)
  reviewedById Int?
  reviewedBy   User?        @relation("CommentReportReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?

  @@unique([commentId, reporterId])
  @@index([commentId, status])
  @@index([reporterId, createdAt])
}

model Tag {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  label     String
  category  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  aliases   TagAlias[]
  postTags  PostTag[]

  @@index([category])
  @@index([isActive])
}

model TagAlias {
  id        Int      @id @default(autoincrement())
  alias     String   @unique
  tagId     Int
  createdAt DateTime @default(now())

  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@index([tagId])
}

model PostTag {
  id         Int           @id @default(autoincrement())
  postId     Int
  tagId      Int
  source     PostTagSource
  confidence Float?
  weight     Float         @default(1.0)
  isPrimary  Boolean       @default(false)
  createdAt  DateTime      @default(now())

  post       Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag        Tag           @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([postId, tagId, source])
  @@index([postId])
  @@index([tagId])
  @@index([tagId, weight])
}