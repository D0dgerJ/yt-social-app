# =========================================
# Core
# =========================================
NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://postgres:password@localhost:5432/social_app
JWT_SECRET=change_me_to_a_long_random_secret

# Frontend / CORS
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# =========================================
# Realtime / Redis
# =========================================
REDIS_URL=

# =========================================
# Storage
# local = Windows/dev
# s3    = production (AWS S3 / DigitalOcean Spaces)
# =========================================
STORAGE_PROVIDER=local

# --- S3 / Spaces (required only if STORAGE_PROVIDER=s3)
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=false

# =========================================
# Whisper
# Leave empty to use defaults:
#   python
#   ./whisper/transcribe.py
# =========================================
WHISPER_PYTHON=python
WHISPER_SCRIPT=
WHISPER_MODEL=small

# =========================================
# Moderation / Cron
# =========================================
MODERATION_OUTBOX_ENABLED=true
STORY_CLEANER_ENABLED=true

# =========================================
# Seed privileged user
# =========================================
SEED_EMAIL=
SEED_USERNAME=
SEED_PASSWORD=
SEED_ROLE=ADMIN