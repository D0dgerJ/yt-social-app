POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=your_database_name

JWT_SECRET=change_me_to_a_long_random_secret

NODE_ENV=production
PORT=5000

CLIENT_URL=http://your-server-ip-or-domain
CORS_ORIGINS=http://your-server-ip-or-domain,http://localhost,http://127.0.0.1

REDIS_URL=
STORAGE_PROVIDER=local

WHISPER_MODEL=small
MODERATION_OUTBOX_ENABLED=true
STORY_CLEANER_ENABLED=true

SEED_EMAIL=
SEED_USERNAME=
SEED_PASSWORD=
SEED_ROLE=ADMIN
